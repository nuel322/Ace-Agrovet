APP_NAME="ACE_AGROVET_CONSULTS"
APP_ENV=production
APP_KEY=SomeRandomKey32CharsExactlyHere!!!
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Configure Production MySQL Database Compatibility
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ace_agrovet_db
DB_USERNAME=ace_agrovet_user
DB_PASSWORD=your_secure_password_here

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Mail setup routed to yahoo
MAIL_MAILER=smtp
MAIL_HOST=smtp.mail.yahoo.com
MAIL_PORT=587
MAIL_USERNAME=ace_vets@yahoo.com
MAIL_PASSWORD=your_yahoo_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="ace_vets@yahoo.com"
MAIL_FROM_NAME="ACE Agrovet Consults"

# Official Administrative Setup
ADMIN_PASSWORD=Aceagrovet1234

# Official Google Gemini API Key - Secure and kept server-side
GEMINI_API_KEY=
